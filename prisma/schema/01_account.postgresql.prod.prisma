enum AccountStatus {
  ACTIVE
  FROZEN
  CLOSED
}

model Account {
  id         String        @id @default(cuid())
  customerId String
  currency   String // keep simple now; we enforce allowed currencies in DTO
  status     AccountStatus @default(ACTIVE)

  // Use Decimal for money in DB
  balance Decimal @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([currency])
}
